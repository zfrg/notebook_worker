{
  "name": "notebook",
  "main": "worker/index.js",
  "compatibility_date": "2026-01-01",
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": false
  },
  "vars": {
    "API_BASE": "",
    "ALLOW_REGISTRATION": "true"
  },
  "kv_namespaces": [
    {
      "binding": "KV"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB"
    }
  ]
}
